# ========================================
# Shatara - Environment Template
# ========================================
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك
# ========================================

APP_NAME=Shatara
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ========================================
# Database
# ========================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=shatara
DB_USERNAME=root
DB_PASSWORD=

# ========================================
# Redis
# ========================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ========================================
# Cache & Queue
# ========================================
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

# ========================================
# Mail
# ========================================
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ========================================
# Feature Flags
# ========================================
FEATURE_AMAZON_SCRAPER=true
FEATURE_NOON_SCRAPER=true
FEATURE_JARIR_SCRAPER=true
FEATURE_EMAIL_NOTIFICATIONS=false
FEATURE_MAINTENANCE_MODE=false

# ========================================
# Scraping Config
# ========================================
SCRAPING_TIMEOUT=30
SCRAPING_RETRIES=3
