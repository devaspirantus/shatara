cat << 'EOF' >> .gitignore

# ========================================
# Shatara - Environment Files (Sensitive)
# ========================================
.env
.env.local
.env.staging
.env.production

# ========================================
# IDE & Editor Files
# ========================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ========================================
# Node & Build Artifacts
# ========================================
/node_modules
/public/build
/public/hot
/public/storage
/storage/*.key

# ========================================
# Laravel Specific
# ========================================
/vendor
.env.backup
.env.production
.phpunit.result.cache
Homestead.json
Homestead.yaml
auth.json
npm-debug.log
yarn-error.log
/.fleet
/.vscode
EOF